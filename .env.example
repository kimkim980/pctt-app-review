# Chọn provider: offline | openai | gemini | groq | openrouter | ollama | lmstudio
AI_PROVIDER=offline
AI_MODEL=
AI_BASE_URL=
AI_API_KEY=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b:free
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=BTS PCTT Local Tool

# Local AI
OLLAMA_MODEL=qwen2.5:7b
LMSTUDIO_MODEL=local-model

# OFFLINE_MODE=1 sẽ chỉ chạy rule engine cứng, không gọi AI
OFFLINE_MODE=1
FAST_MODE=1
RUN_TIMEOUT_SECONDS=300
AI_TIMEOUT_SECONDS=300
